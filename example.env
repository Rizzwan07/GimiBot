# Environment Variables Configuration
# ======================================
# This file shows environment variables needed for the app.
# Copy this to .env and add your actual values!

# --------------------------------------
# Google Gemini API Key (REQUIRED)
# --------------------------------------
# Get your API key from: https://aistudio.google.com/apikey
# This key is FREE for personal use (generous daily quota)
# NEVER share or commit this key to git!

GOOGLE_API_KEY=your_api_key_here

# --------------------------------------
# How to get your API key:
# --------------------------------------
# 1. Go to https://aistudio.google.com/apikey
# 2. Sign in with your Google account
# 3. Click "Create API Key"
# 4. Copy the generated key
# 5. Paste it in your .env file as shown above
# 6. Start the app!

# --------------------------------------
# How to use:
# --------------------------------------
# 1. Copy this file: cp example.env .env
# 2. Edit .env and replace "your_api_key_here" with your actual key
# 3. NEVER commit .env to git - it's already in .gitignore!
# 4. Run the app: python app.py

# --------------------------------------
# Why use .env?
# --------------------------------------
# - Keeps secrets out of your code
# - Easy to change settings without editing code
# - Different values for different computers
# - Standard practice in professional development